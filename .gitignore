# ========================
# 1. 依赖文件 (体积巨大，无需上传，用户会自己构建)
# ========================
node_modules/
.wrangler/
.dev.vars

# ========================
# 2. 日志与运行缓存 (本地运行产生的垃圾文件)
# ========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# ========================
# 3. 数据库与本地挂载数据 (⚠️ 极度重要)
# ========================
# 拦截你的本地 Redis 数据库文件，防止把你的运行状态和车主会话记录传到网上
redis_data/
data/
db/

# ========================
# 4. 环境变量文件 (防患于未然)
# ========================
# 虽然你现在没用 .env，但这是 Node.js 项目的通用规范，写上更显专业
.env
.env.local
.env.*.local

# ========================
# 5. 操作系统自动生成的隐藏文件
# ========================
# Mac 系统专属
.DS_Store
.AppleDouble
.LSOverride
# Windows 系统专属
Thumbs.db
ehthumbs.db
desktop.ini